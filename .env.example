# SECURITY CONFIGURATION
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3000

# Encryption Keys
MASTER_ENCRYPTION_KEY=your-256-bit-hex-key-here
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars
AES_ENCRYPTION_KEY=your-aes-256-key-here

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/secure_ai_db
DATABASE_ENCRYPTION_KEY=your-database-encryption-key
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# AUTHENTICATION
BCRYPT_ROUNDS=12
MFA_ENABLED=true
MFA_WINDOW=2

# RATE LIMITING
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# AI MODELS
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=your-openai-key
CLAUDE_API_KEY=your-claude-key
GEMINI_API_KEY=your-gemini-key

# MESSAGING
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TELEGRAM_BOT_TOKEN=your-telegram-token

# VAULT
VAULT_ENABLED=true
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-vault-token